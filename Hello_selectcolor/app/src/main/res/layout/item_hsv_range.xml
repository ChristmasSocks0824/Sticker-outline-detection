<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="8dp">

    <View
        android:id="@+id/viewColorPreview"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="#CCCCCC"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/txtRangeName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Range Name"
            android:textStyle="bold"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/txtRangeValues"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="H:0-180 S:0-255 V:0-255"
            android:textSize="12sp"/>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnEditRange"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_menu_edit"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="編輯"/>

    <ImageButton
        android:id="@+id/btnDeleteRange"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_menu_delete"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="刪除"/>

</LinearLayout>
